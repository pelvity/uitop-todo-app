# ── Frontend (Next.js / Vercel) ──
# Backend API URL. Set in Vercel dashboard (Settings → Environment Variables)
# No default — rewrites fallback is in vercel.json
# API_URL=https://your-backend.com

# ── Backend (NestJS / Render) ──
NODE_ENV=production
PORT=3001

# Path to SQLite database file (persistent disk path on Render)
DATABASE_PATH=/var/data/todo.db
