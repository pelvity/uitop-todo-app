{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "API_URL": "https://uitop-api.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://uitop-api.onrender.com/:path*"
    }
  ]
}
